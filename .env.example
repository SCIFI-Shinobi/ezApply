# --- Telegram bot (the one you talk to) ---
BOT_TOKEN=your_bot_father_token_here
YOUR_TELEGRAM_USER_ID=your_numeric_telegram_id   # so the bot only accepts your resume/commands

# --- Telethon userbot (reads channels using YOUR personal account) ---
TG_API_ID=123456                    # from https://my.telegram.org
TG_API_HASH=your_api_hash_here
TG_SESSION_STRING=                  # leave empty first run; script will print one to save here

# --- Database (Supabase Postgres connection string) ---
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# --- Matching ---
MATCH_THRESHOLD=0.55                # cosine similarity 0-1, tune after first week of data
KEYWORD_MATCH_THRESHOLD=50          # hardcoded rules score 0-100
APPLYFLOW_PROFILE_PATH=             # optional override for ../ApplyFlow/profile.json

# --- Email outreach (/sendemail, /sendremoteemails) ---
# Use a Gmail App Password (NOT your main Gmail password).
# How to get one: Google account → Security → 2-Step Verification → App passwords
EMAIL_FROM=your_gmail@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_16_chars
SMTP_HOST=smtp.gmail.com            # change if using another SMTP provider
SMTP_PORT=587                       # 587 = STARTTLS (recommended), 465 = SSL
